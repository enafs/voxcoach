# VoxCoach — copie para `.env` e preencha. Nunca commite o `.env` real.

# Backend de LLM: claude | openai
VOXCOACH_LLM_BACKEND=claude

# Chaves de API — use a do SEU provedor (custo e privacidade ficam com você, D05)
VOXCOACH_ANTHROPIC_API_KEY=
VOXCOACH_OPENAI_API_KEY=

# Modelo (padrão: rápido p/ tempo real) e tamanho da resposta
VOXCOACH_LLM_MODEL=claude-haiku-4-5-20251001
VOXCOACH_LLM_MAX_TOKENS=120

# TTS (edge-tts)
VOXCOACH_TTS_VOICE=pt-BR-AntonioNeural
VOXCOACH_TTS_RATE=+0%

# Engine
VOXCOACH_POLL_INTERVAL_SECONDS=1.5
VOXCOACH_SPEAK_COOLDOWN_SECONDS=8.0
